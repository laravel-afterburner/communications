{
    "name": "laravel-afterburner/communications",
    "description": "Team announcements and discussion threads for Afterburner applications",
    "version": "1.7.6",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel-afterburner/jetstream": "^1.0|dev-master",
        "livewire/livewire": "^3.5"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Afterburner\\Communications\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Afterburner\\Communications\\Tests\\": "tests/",
            "App\\Models\\": "tests/Fixtures/Models/",
            "App\\Traits\\": "tests/Fixtures/Traits/",
            "App\\Support\\Audit\\": "tests/Fixtures/Support/Audit/",
            "Tests\\Concerns\\": "tests/Concerns/"
        },
        "classmap": [
            "tests/Fixtures/Support/EntityLabel.php",
            "tests/Fixtures/Support/TeamPermissionGate.php",
            "tests/Fixtures/Support/PageHeader.php",
            "tests/Fixtures/Support/TeamDateTime.php",
            "tests/Fixtures/Support/Concerns/ChecksOptionalSubscriptionEntitlement.php",
            "tests/Fixtures/Database/Seeders/Concerns/AssignsPermissionsToTeamOwners.php",
            "tests/Fixtures/Support/Audit/AuditLogger.php"
        ]
    },
    "scripts": {
        "test": "phpunit",
        "pint": "pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Afterburner\\Communications\\Providers\\CommunicationsServiceProvider"
            ],
            "commands": [
                "Afterburner\\Communications\\Console\\Commands\\InstallCommand"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
